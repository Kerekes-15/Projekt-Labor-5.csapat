<Page
    x:Class="VTrailer.Presentation.MyBookingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:VTrailer.Presentation"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Saját Foglalásaim" FontSize="28" FontWeight="Bold" Margin="0,0,0,24" />

        <ListView x:Name="BookingsListView" Grid.Row="1" SelectionMode="None">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border Background="{ThemeResource SurfaceVariantBrush}" CornerRadius="8" Padding="16" Margin="0,0,0,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="{Binding TrailerName}" FontSize="18" FontWeight="Bold"/>
                                <TextBlock Text="{Binding DisplayDate}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Margin="0,4,0,0"/>
                                <TextBlock Text="{Binding DisplayTimeSlot}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>

                            <TextBlock Grid.Column="1" Text="{Binding DisplayPrice}" FontSize="18" FontWeight="Bold" Foreground="{ThemeResource SystemAccentColor}" VerticalAlignment="Center" Margin="0,0,24,0"/>

                            <Button Grid.Column="2" Content="Törlés" Foreground="White" CornerRadius="6" VerticalAlignment="Center" Click="OnDeleteBookingClick">
                                <Button.Resources>
                                    <SolidColorBrush x:Key="ButtonBackground" Color="#d32f2f"/>
                                    <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#b71c1c"/>
                                    <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#7f0000"/>
                                </Button.Resources>
                            </Button>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <TextBlock x:Name="EmptyStateText" Text="Még nincs egyetlen aktív foglalásod sem." 
                   FontSize="16" Foreground="{ThemeResource TextFillColorSecondaryBrush}" 
                   HorizontalAlignment="Center" VerticalAlignment="Center" Grid.Row="1" Visibility="Collapsed"/>
    </Grid>
</Page>
