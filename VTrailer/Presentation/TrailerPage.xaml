<Page x:Class="VTrailer.Presentation.TrailerPage"
      x:Name="RootPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:VTrailer.Presentation"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:utu="using:Uno.Toolkit.UI"
      xmlns:um="using:Uno.Material"
      xmlns:converters="using:VTrailer.Converters"
      mc:Ignorable="d"
      Background="{ThemeResource BackgroundBrush}">

    <Page.Resources>
        <converters:StatusToColorConverter x:Key="StatusToColorConverter" />
    </Page.Resources>

    <Grid Margin="16" MaxWidth="1400" HorizontalAlignment="Center">

        <GridView ItemsSource="{Binding Trailers}" SelectionMode="None" HorizontalAlignment="Stretch">

            <GridView.Header>
                <TextBlock Text="Kínálatunk" FontSize="28" FontWeight="Bold" Margin="10,0,0,24" />
            </GridView.Header>

            <GridView.ItemTemplate>
                <DataTemplate>

                    <Border Width="320" Margin="10" CornerRadius="12" 
                            BorderBrush="{ThemeResource SurfaceVariantBrush}" BorderThickness="1"
                            Background="{ThemeResource SurfaceBrush}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="160" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0" Background="{ThemeResource SurfaceVariantBrush}" CornerRadius="12,12,0,0">

                                <FontIcon Glyph="&#xEB4D;" FontSize="64" Foreground="{ThemeResource OutlineBrush}" Opacity="0.3"/>

                                <Image Source="{Binding ImageUrl}" Stretch="UniformToFill" />

                                <Border HorizontalAlignment="Right" VerticalAlignment="Top" Margin="12" Padding="8,4" CornerRadius="6" 
            Background="{Binding Status, Converter={StaticResource StatusToColorConverter}}">
                                    <TextBlock Text="{Binding Status}" Foreground="White" FontSize="12" FontWeight="Bold" />
                                </Border>
                            </Grid>

                            <StackPanel Grid.Row="1" Padding="16" Spacing="8">
                                <TextBlock Text="{Binding BrandAndModel}" FontSize="20" FontWeight="Bold" TextTrimming="CharacterEllipsis" />
                                <TextBlock Text="{Binding Category}" FontSize="14" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

                                <Border Background="{ThemeResource SurfaceVariantBrush}" HorizontalAlignment="Left" Padding="6,2" CornerRadius="4" Margin="0,4,0,8">
                                    <TextBlock Text="{Binding LicensePlate}" FontSize="12" FontFamily="Consolas" FontWeight="SemiBold" />
                                </Border>

                                <Grid Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Össztömeg" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                        <TextBlock FontSize="14" FontWeight="SemiBold">
                                            <Run Text="{Binding TotalWeightKg}" />
                                            <Run Text=" kg" />
                                        </TextBlock>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="Teherbírás" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                        <TextBlock FontSize="14" FontWeight="SemiBold">
                                            <Run Text="{Binding PayloadCapacityKg}" />
                                            <Run Text=" kg" />
                                        </TextBlock>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>

                            <Grid Grid.Row="2" Padding="16" BorderBrush="{ThemeResource SurfaceVariantBrush}" BorderThickness="0,1,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Napi díj" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    <TextBlock FontSize="20" FontWeight="Bold" Foreground="#0078D7">
                                        <Run Text="{Binding DailyRateFormatted}" />
                                        <Run Text=" Ft" />
                                    </TextBlock>
                                </StackPanel>

                                <Button Grid.Column="1" Content="Részletek" Style="{StaticResource AccentButtonStyle}" Width="110" />
                            </Grid>
                        </Grid>
                    </Border>

                </DataTemplate>
            </GridView.ItemTemplate>
        </GridView>
    </Grid>
</Page>
