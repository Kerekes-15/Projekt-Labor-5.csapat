<Page x:Class="VTrailer.Presentation.IntroPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:VTrailer.Presentation"
      Background="{ThemeResource BackgroundBrush}">

    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="24">
        <TextBlock Text="Welcome to VTrailer!" FontSize="32" FontWeight="Bold" />
        <TextBlock Text="This is some placeholder intro text." FontSize="18" />
        <Button Content="Login"
                Width="160"
                Height="48"
                Click="LoginButton_Click"/>
    </StackPanel>
</Page>
