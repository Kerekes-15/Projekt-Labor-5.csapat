<Page
    x:Class="VTrailer.Presentation.TrailerManagementPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Utánfutók Kezelése" FontSize="28" FontWeight="Bold" VerticalAlignment="Center"/>
            <Button Grid.Column="1" Content="+ Új utánfutó hozzáadása" Click="OnAddNewTrailerClick" Height="40" CornerRadius="8">
                <Button.Resources>
                    <SolidColorBrush x:Key="ButtonBackground" Color="#005fb8"/>
                    <SolidColorBrush x:Key="ButtonForeground" Color="White"/>
                    <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#004c93"/>
                </Button.Resources>
            </Button>
        </Grid>

        <ListView x:Name="TrailersListView" Grid.Row="1" SelectionMode="None">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border Background="{ThemeResource SurfaceVariantBrush}" CornerRadius="8" Padding="16" Margin="0,0,0,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Width="80" Height="50" CornerRadius="6" Margin="0,0,16,0">
                                <Image Source="{Binding ImageUrl}" Stretch="UniformToFill"/>
                            </Border>

                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="{Binding BrandAndModel}" FontSize="18" FontWeight="Bold"/>
                                <TextBlock Text="{Binding LicensePlate}" FontSize="14" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Margin="0,4,0,0"/>
                                <TextBlock Text="{Binding Category}" FontSize="14" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="Napi díj:" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <TextBlock Text="{Binding DailyRateFormatted}" FontSize="15" FontWeight="SemiBold"/>
                                <TextBlock Text="Kaució:" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Margin="0,4,0,0"/>
                                <TextBlock Text="{Binding DepositFormatted}" FontSize="15" FontWeight="SemiBold"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                <TextBlock Text="Státusz:" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <TextBlock Text="{Binding Status}" FontSize="16" FontWeight="Bold" Margin="0,4,0,0"/>
                            </StackPanel>

                            <StackPanel Grid.Column="4" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">

                                <Button Click="OnEditTrailerClick" Background="Transparent" BorderBrush="Transparent" Tag="{Binding}" ToolTipService.ToolTip="Szerkesztés">
                                    <SymbolIcon Symbol="Edit" Foreground="Black" />
                                </Button>

                                <Button Click="DeleteButton_Click" Background="Transparent" BorderBrush="Transparent" Tag="{Binding}" ToolTipService.ToolTip="Törlés">
                                    <SymbolIcon Symbol="Delete" Foreground="Red" />
                                </Button>

                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
