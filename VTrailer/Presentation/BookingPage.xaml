<Page
    x:Class="VTrailer.Presentation.BookingPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <ScrollViewer>
        <Grid Padding="24" MaxWidth="1280" ColumnSpacing="24" RowSpacing="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="380" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Row="0"
                    Grid.RowSpan="2"
                    Background="{ThemeResource SurfaceBrush}"
                    BorderBrush="{ThemeResource SurfaceVariantBrush}"
                    BorderThickness="1"
                    CornerRadius="16"
                    Padding="24">
                <StackPanel Spacing="18">
                    <TextBlock Text="Utánfutó foglalása" FontSize="28" FontWeight="Bold" />
                    <TextBlock Text="Válassz utánfutót, időpontot, majd döntsd el, hogy telephelyi átvételt vagy kiszállítást kérsz."
                               TextWrapping="WrapWholeWords"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

                    <ComboBox Header="Melyik utánfutót szeretnéd?"
                              Width="320"
                              ItemsSource="{Binding AvailableTrailers}"
                              SelectedItem="{Binding SelectedTrailer, Mode=TwoWay}"
                              DisplayMemberPath="BrandAndModel"
                              PlaceholderText="Válassz a listából..." />

                    <CalendarDatePicker Header="Melyik napra?"
                                        Width="320"
                                        Date="{Binding SelectedBookingDate, Mode=TwoWay}" />

                    <ComboBox Header="Idősáv"
                              Width="320"
                              ItemsSource="{Binding TimeSlots}"
                              SelectedItem="{Binding SelectedTimeSlot, Mode=TwoWay}"
                              PlaceholderText="Válassz idősávot..." />

                    <Border Background="{ThemeResource SurfaceVariantBrush}"
                            BorderBrush="{ThemeResource SurfaceVariantBrush}"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="16">
                        <StackPanel Spacing="10">
                            <TextBlock Text="Átvételi mód" FontSize="18" FontWeight="SemiBold" />
                            <RadioButton x:Name="PickupOption"
                                         Content="Pickup"
                                         GroupName="TransportMode"
                                         IsChecked="True"
                                         Checked="PickupOption_Checked" />
                            <RadioButton x:Name="DeliveryOption"
                                         Content="Delivery"
                                         GroupName="TransportMode"
                                         Checked="DeliveryOption_Checked" />
                            <TextBlock Text="Pickup esetén nincs extra díj, és nem szükséges térképes helyválasztás."
                                       TextWrapping="WrapWholeWords"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                    </Border>

                    <Border Background="{ThemeResource SurfaceVariantBrush}"
                            BorderBrush="{ThemeResource SurfaceVariantBrush}"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="16">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Árkalkuláció" FontSize="18" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding RentalPriceSummaryText}" />
                            <TextBlock Text="{Binding FeeSummaryText}" />
                            <TextBlock Text="{Binding TotalPriceSummaryText}"
                                       FontSize="22"
                                       FontWeight="Bold"
                                       Foreground="{ThemeResource SystemAccentColor}" />
                            <TextBlock Text="{Binding DeliveryStatusMessage}"
                                       TextWrapping="WrapWholeWords"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                    </Border>

                    <TextBlock Text="{Binding StatusMessage}"
                               Visibility="{Binding StatusVisibility}"
                               TextWrapping="WrapWholeWords"
                               Foreground="{Binding StatusForeground}" />

                    <Button Content="Foglalás véglegesítése"
                            Width="320"
                            Height="48"
                            FontSize="16"
                            Style="{ThemeResource AccentButtonStyle}"
                            Command="{Binding SubmitBookingCommand}"
                            IsEnabled="{Binding CanSubmit}" />
                </StackPanel>
            </Border>

            <Border Grid.Row="0"
                    Grid.Column="1"
                    Background="{ThemeResource SurfaceBrush}"
                    BorderBrush="{ThemeResource SurfaceVariantBrush}"
                    BorderThickness="1"
                    CornerRadius="16"
                    Padding="20"
                    Visibility="{Binding MapVisibility}">
                <StackPanel Spacing="12">
                    <TextBlock Text="Kiszállítási hely kiválasztása" FontSize="24" FontWeight="Bold" />
                    <TextBlock Text="Delivery választásakor a térkép megjelenik, és a foglalás csak egy érvényes hely kiválasztása után engedhető tovább."
                               TextWrapping="WrapWholeWords"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <Border CornerRadius="14"
                            BorderBrush="{ThemeResource SurfaceVariantBrush}"
                            BorderThickness="1"
                            Height="430">
                        <WebView2 x:Name="MapView"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Stretch"
                                  WebMessageReceived="MapView_WebMessageReceived" />
                    </Border>
                </StackPanel>
            </Border>

            <Border Grid.Row="1"
                    Grid.Column="1"
                    Background="{ThemeResource SurfaceBrush}"
                    BorderBrush="{ThemeResource SurfaceVariantBrush}"
                    BorderThickness="1"
                    CornerRadius="16"
                    Padding="20">
                <StackPanel Spacing="12">
                    <TextBlock Text="Kiválasztott hely" FontSize="22" FontWeight="Bold" />
                    <TextBlock Text="{Binding SelectedLocationLabel}" TextWrapping="WrapWholeWords" />
                    <TextBlock Text="{Binding SelectedCoordinates}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <TextBlock Text="{Binding DistanceSummaryText}" />
                    <TextBlock Text="Pickup esetén ezt a részt figyelmen kívül hagyhatod."
                               Visibility="{Binding PickupHintVisibility}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               TextWrapping="WrapWholeWords" />
                    <TextBlock Text="Delivery esetén kötelező egy térképes helyet kiválasztani, különben a foglalás nem véglegesíthető."
                               Visibility="{Binding DeliveryValidationVisibility}"
                               Foreground="{ThemeResource SystemAccentColor}"
                               TextWrapping="WrapWholeWords" />
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>
