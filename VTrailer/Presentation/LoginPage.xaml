<Page x:Class="VTrailer.Presentation.LoginPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:VTrailer.Presentation"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:uen="using:Uno.Extensions.Navigation.UI"
      xmlns:utu="using:Uno.Toolkit.UI"
      xmlns:um="using:Uno.Material"
      mc:Ignorable="d"
      NavigationCacheMode="Required"
      Background="{ThemeResource BackgroundBrush}">

    <Grid>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="20" Width="320">

            <TextBlock Text="VTrailer Kölcsönző" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center" />
            <TextBlock Text="Kérlek jelentkezz be a folytatáshoz!" FontSize="14" HorizontalAlignment="Center" Margin="0,0,0,10" Opacity="0.7"/>

            <TextBox Text="{Binding Username, Mode=TwoWay}" PlaceholderText="Felhasználónév" HorizontalAlignment="Stretch" />
            <PasswordBox Password="{Binding Password, Mode=TwoWay}" PlaceholderText="Jelszó" HorizontalAlignment="Stretch" />

            <TextBlock Text="Hibás felhasználónév vagy jelszó!" Foreground="Red" 
                       Visibility="{Binding HasError, Converter={StaticResource BoolToVisibilityConverter}}" 
                       HorizontalAlignment="Center"/>
            
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="5">
                <TextBlock Text="Még nincs fiókod?" VerticalAlignment="Center" Opacity="0.8"/>
                <HyperlinkButton Content="Regisztrálj" Command="{Binding GoToRegisterCommand}" Padding="0"/>
            </StackPanel>

            <Button Content="Bejelentkezés" Command="{Binding LoginCommand}" 
                    Background="#5b4bc4" Foreground="White" HorizontalAlignment="Stretch" Height="40" Margin="0,10,0,0"/>

        </StackPanel>
    </Grid>
</Page>
